---
import BrandLogo from "~/components/BrandLogo.astro";
import SocialContactActions from "~/components/SocialContactActions.astro";
import { pagePath } from "~/utils/paths";

const navItems = [
  ["Inicio", "/"],
  ["Servicios", "/servicios"],
  ["Portafolio", "/portafolio"],
  ["Nosotros", "/nosotros"],
  ["Crew", "/crew"],
  ["Contacto", "/contacto"],
];
---

<header class="site-header" data-site-header>
  <div class="container header-inner">
    <a class="brand" href={pagePath("/")} aria-label="frato inicio">
      <BrandLogo />
    </a>
    <nav id="primary-nav" aria-label="Navegacion principal">
      {navItems.map(([label, href]) => <a href={pagePath(href)}>{label}</a>)}
    </nav>
    <div class="header-actions">
      <SocialContactActions compact />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(5, 15, 35, 0.8);
    backdrop-filter: blur(18px);
  }

  .header-inner {
    display: grid;
    grid-template-columns: 190px minmax(0, 1fr) 190px;
    min-height: 82px;
    align-items: center;
    gap: 24px;
  }

  .brand {
    display: grid;
    width: 148px;
    min-height: 50px;
    align-items: center;
    padding: 8px 16px;
    border-radius: 8px;
    background: rgba(7, 20, 39, 0.72);
    justify-self: start;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(14px, 2.4vw, 28px);
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.9rem;
  }

  nav a {
    color: inherit;
    transition: color 160ms ease;
  }

  nav a:hover {
    color: var(--frato-white);
  }

  .header-actions {
    display: flex;
    justify-content: end;
  }

  .header-actions :global(.social-actions) {
    flex-wrap: nowrap;
    gap: 10px;
  }

  .header-actions :global(.social-actions--compact .social-action) {
    min-height: 42px;
    width: 42px;
    justify-content: center;
    padding: 0;
    border-radius: 8px;
  }

  @media (max-width: 930px) {
    .header-inner {
      grid-template-columns: 1fr;
      gap: 10px;
      padding-block: 12px;
    }

    .brand {
      width: 108px;
      height: auto;
      justify-self: center;
    }

    .header-actions {
      justify-content: center;
    }

    nav {
      flex-wrap: wrap;
      gap: 10px 18px;
      font-size: 0.84rem;
    }

    nav a {
      padding: 4px 0;
    }
  }
</style>

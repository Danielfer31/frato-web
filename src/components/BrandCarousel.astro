---
import CasePreviewPanel from "~/components/CasePreviewPanel.astro";
import type { CaseStudy } from "~/data/cases";

interface Props {
  cases: CaseStudy[];
}

const { cases } = Astro.props;
---

<section class="brand-lab" id="casos" data-brand-carousel>
  <div class="brand-lab__intro">
    <div>
      <p class="eyeless-label">Marcas priorizadas</p>
      <h2 class="headline">Toca una marca y mira que historia estamos armando.</h2>
    </div>
    <p>
      La matriz de marcas del PDF funciona como referencia de identidad. Aqui solo publicamos material autorizado y dejamos
      cada caso listo para recibir fotos, reels, historias y resultados reales.
    </p>
  </div>

  <div class="brand-lab__grid">
    <div class="brand-lab__selector">
      <div
        class="brand-lab__stage"
        aria-label="Vista destacada del caso activo"
        aria-live="polite"
        aria-roledescription="carousel"
        data-brand-swipe
      >
        {cases.map((caseStudy, index) => (
          <article
            class:list={["brand-stage", { "is-active": index === 0 }]}
            id={`case-stage-${caseStudy.slug}`}
            data-case-stage={caseStudy.slug}
            aria-hidden={index === 0 ? "false" : "true"}
            inert={index === 0 ? undefined : true}
            style={`--case-accent: ${caseStudy.accent}`}
          >
            <div class:list={["brand-stage__media", { "brand-stage__media--logo": caseStudy.logo }]}>
              {caseStudy.logo ? (
                <img src={caseStudy.logo} alt={`Logo ${caseStudy.name}`} loading="lazy" />
              ) : (
                <>
                  <span>{caseStudy.name}</span>
                  <small>Identidad pendiente de autorizacion</small>
                </>
              )}
            </div>
            <div class="brand-stage__meta">
              <strong>{caseStudy.sector}</strong>
              <p>{caseStudy.evidence[0]}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="brand-rail" role="tablist" aria-label="Casos de marca">
        {cases.map((caseStudy, index) => (
          <button
            class:list={["brand-tab", { "is-active": index === 0 }]}
            type="button"
            role="tab"
            id={`case-tab-${caseStudy.slug}`}
            aria-selected={index === 0 ? "true" : "false"}
            aria-controls={`case-panel-${caseStudy.slug}`}
            tabindex={index === 0 ? "0" : "-1"}
            data-case-tab={caseStudy.slug}
            style={`--case-accent: ${caseStudy.accent}`}
          >
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{caseStudy.name}</strong>
          </button>
        ))}
      </div>

      <div class="brand-controls" aria-hidden="true">
        <div class="brand-progress">
          <span data-case-progress style={`width: ${100 / cases.length}%`}></span>
        </div>
      </div>
      <button type="button" class="visually-hidden" data-case-prev aria-label="Caso anterior">Anterior</button>
      <button type="button" class="visually-hidden" data-case-next aria-label="Caso siguiente">Siguiente</button>
    </div>

    <CasePreviewPanel cases={cases} />
  </div>
</section>

<script>
  const carousels = document.querySelectorAll("[data-brand-carousel]");

  carousels.forEach((carousel) => {
    const tabs = Array.from(carousel.querySelectorAll<HTMLElement>("[data-case-tab]"));
    const stages = Array.from(carousel.querySelectorAll<HTMLElement>("[data-case-stage]"));
    const panels = Array.from(carousel.querySelectorAll<HTMLElement>("[data-case-panel]"));
    const progress = carousel.querySelector<HTMLElement>("[data-case-progress]");
    const prev = carousel.querySelector<HTMLElement>("[data-case-prev]");
    const next = carousel.querySelector<HTMLElement>("[data-case-next]");
    const swipeSurface = carousel.querySelector<HTMLElement>("[data-brand-swipe]");
    let activeIndex = 0;
    let swipeStart = 0;

    if (!tabs.length) {
      return;
    }

    const activate = (index: number, shouldFocus = false) => {
      activeIndex = (index + tabs.length) % tabs.length;
      const slug = tabs[activeIndex].getAttribute("data-case-tab");

      tabs.forEach((tab) => {
        const isActive = tab.getAttribute("data-case-tab") === slug;
        tab.classList.toggle("is-active", isActive);
        tab.setAttribute("aria-selected", String(isActive));
        tab.tabIndex = isActive ? 0 : -1;
      });

      stages.forEach((stage) => {
        const isActive = stage.getAttribute("data-case-stage") === slug;
        stage.classList.toggle("is-active", isActive);
        stage.setAttribute("aria-hidden", String(!isActive));
        stage.toggleAttribute("inert", !isActive);
      });

      panels.forEach((panel) => {
        const isActive = panel.getAttribute("data-case-panel") === slug;
        panel.classList.toggle("is-active", isActive);
        panel.setAttribute("aria-hidden", String(!isActive));
        panel.tabIndex = isActive ? 0 : -1;
        panel.toggleAttribute("inert", !isActive);
      });

      if (progress) {
        progress.style.width = `${((activeIndex + 1) / tabs.length) * 100}%`;
      }

      tabs[activeIndex].scrollIntoView({ block: "nearest", inline: "center" });

      if (shouldFocus) {
        tabs[activeIndex].focus();
      }
    };

    tabs.forEach((tab, index) => {
      tab.addEventListener("click", () => activate(index));
      tab.addEventListener("keydown", (event) => {
        if (!(event instanceof KeyboardEvent)) {
          return;
        }

        const keyActions: Record<string, number> = {
          ArrowLeft: activeIndex - 1,
          ArrowRight: activeIndex + 1,
          Home: 0,
          End: tabs.length - 1,
        };

        if (event.key in keyActions) {
          event.preventDefault();
          activate(keyActions[event.key], true);
        }
      });
    });

    prev?.addEventListener("click", () => activate(activeIndex - 1, true));
    next?.addEventListener("click", () => activate(activeIndex + 1, true));

    swipeSurface?.addEventListener("pointerdown", (event) => {
      swipeStart = event.clientX;
    });

    swipeSurface?.addEventListener("pointerup", (event) => {
      const distance = event.clientX - swipeStart;

      if (Math.abs(distance) > 42) {
        activate(activeIndex + (distance < 0 ? 1 : -1), true);
      }
    });

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let timer: number | null = null;
    const start = () => {
      if (reduceMotion || timer !== null) return;
      timer = window.setInterval(() => activate(activeIndex + 1), 5000);
    };
    const stop = () => {
      if (timer !== null) {
        window.clearInterval(timer);
        timer = null;
      }
    };

    carousel.addEventListener("mouseenter", stop);
    carousel.addEventListener("mouseleave", start);
    carousel.addEventListener("focusin", stop);
    carousel.addEventListener("focusout", start);
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stop();
      else start();
    });

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => (entry.isIntersecting ? start() : stop()));
      },
      { threshold: 0.25 }
    );
    io.observe(carousel);
  });
</script>

<style>
  .brand-lab {
    padding: clamp(70px, 10vw, 130px) 0;
    overflow: hidden;
  }

  .brand-lab__intro {
    width: min(var(--container), calc(100% - 40px));
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.52fr);
    gap: clamp(28px, 7vw, 86px);
    align-items: end;
    margin-inline: auto;
    margin-bottom: clamp(34px, 6vw, 64px);
  }

  .brand-lab__intro h2,
  .brand-lab__intro p {
    margin: 0;
  }

  .brand-lab__intro > p {
    color: rgba(255, 255, 255, 0.66);
    line-height: 1.7;
  }

  .brand-lab__grid {
    width: min(var(--container), calc(100% - 40px));
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.85fr);
    gap: 22px;
    margin-inline: auto;
  }

  .brand-lab__selector {
    display: grid;
    gap: 16px;
    min-width: 0;
  }

  .brand-lab__stage {
    position: relative;
    min-height: 440px;
    touch-action: pan-y;
  }

  .brand-stage {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    gap: 14px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 8px;
    padding: 14px;
    background:
      radial-gradient(circle at 24% 20%, color-mix(in srgb, var(--case-accent) 26%, transparent), transparent 16rem),
      rgba(11, 24, 48, 0.76);
    opacity: 0;
    pointer-events: none;
    transform: scale(1.02) translateX(12px);
    transition: opacity 700ms ease, transform 900ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .brand-stage.is-active {
    opacity: 1;
    pointer-events: auto;
    transform: scale(1) translateX(0);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .brand-stage__media {
    display: grid;
    align-content: end;
    gap: 12px;
    min-height: 0;
    border: 1px dashed rgba(255, 255, 255, 0.23);
    border-radius: 8px;
    padding: clamp(20px, 4vw, 34px);
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.015)),
      rgba(5, 15, 35, 0.74);
  }

  .brand-stage__media--logo {
    place-content: center;
    place-items: center;
    border-style: solid;
    border-color: color-mix(in srgb, var(--case-accent) 40%, rgba(255, 255, 255, 0.14));
  }

  .brand-stage__media--logo img {
    max-width: min(72%, 340px);
    max-height: 78%;
    width: auto;
    height: auto;
    object-fit: contain;
    mix-blend-mode: screen;
  }

  .brand-stage__media span {
    max-width: 95%;
    color: var(--frato-white);
    font-size: clamp(3rem, 9vw, 7rem);
    font-weight: 850;
    line-height: 0.96;
  }

  .brand-stage__media small {
    color: var(--case-accent);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .brand-stage__meta {
    display: grid;
    grid-template-columns: 0.7fr 1fr;
    gap: 18px;
    border-radius: 8px;
    padding: 22px 22px 26px;
    margin-top: 6px;
    background: rgba(5, 15, 35, 0.64);
  }

  .brand-stage__meta strong {
    color: var(--case-accent);
  }

  .brand-stage__meta p {
    margin: 0;
    color: rgba(255, 255, 255, 0.67);
    line-height: 1.5;
  }

  .brand-rail {
    display: grid;
    grid-template-columns: repeat(6, minmax(120px, 1fr));
    gap: 8px;
    overflow-x: auto;
    padding-bottom: 4px;
    scrollbar-width: none;
  }

  .brand-rail::-webkit-scrollbar {
    display: none;
  }

  .brand-tab {
    display: grid;
    gap: 10px;
    min-height: 92px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    padding: 12px;
    background: rgba(5, 15, 35, 0.64);
    color: rgba(255, 255, 255, 0.72);
    text-align: left;
    cursor: pointer;
    transition: border-color 180ms ease, background 180ms ease, transform 180ms ease;
  }

  .brand-tab:hover,
  .brand-tab:focus-visible,
  .brand-tab.is-active {
    border-color: var(--case-accent);
    background: color-mix(in srgb, var(--case-accent) 12%, rgba(5, 15, 35, 0.86));
    transform: translateY(-2px);
  }

  .brand-tab:focus-visible {
    outline: 2px solid var(--case-accent, var(--frato-orange));
    outline-offset: 3px;
  }

  .brand-tab span {
    color: var(--case-accent);
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.14em;
  }

  .brand-tab strong {
    font-size: 0.94rem;
  }

  .brand-controls {
    display: block;
    padding-top: 4px;
  }

  .brand-progress {
    height: 2px;
    background: rgba(255, 255, 255, 0.12);
  }

  .brand-progress span {
    display: block;
    height: 100%;
    background: var(--frato-orange);
    transition: width 220ms ease;
  }

  @media (max-width: 980px) {
    .brand-lab__intro,
    .brand-lab__grid {
      grid-template-columns: 1fr;
      width: min(var(--container), calc(100% - 28px));
    }
  }

  @media (max-width: 620px) {
    .brand-lab__stage {
      min-height: 390px;
    }

    .brand-stage__meta {
      grid-template-columns: 1fr;
    }
  }
</style>

  "06_gassata.png",
  "07_cda_santa_cruz.png",
  "08_giovanna_maroso.png",
  "09_trip_burger.png",
  "10_pizzas_mil.png",
  "11_cvco_colombia_vape_company.png",
  "12_furtivo_taqueria.png",
  "13_beer_cave.png",
  "14_x_logo.png",
  "15_nohemi_haddad.png",
  "16_mar_brasas.png",
  "17_perfumarte.png",
  "18_berrocal.png",
  "19_dragon_rojo.png",
  "20_le_bistrot.png",
  "21_campo.png",
  "22_koncres.png",
  "23_green_padel_sport.png",
  "24_senderos_artisan_bakery.png",

---
import { getCaseMedia } from "~/data/caseMedia";

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const media = getCaseMedia(slug);
---

{media.length > 0 && (
  <div class="case-gallery">
    {media.map((item) => (
      <figure class:list={["gallery-item", `gallery-item--${item.type}`]}>
        {item.type === "reel" ? (
          <video
            src={item.src}
            poster={item.poster}
            controls
            playsinline
            preload="none"
            loop
            muted
          ></video>
        ) : (
          <img src={item.src} alt="Pieza de contenido" loading="lazy" decoding="async" />
        )}
        <figcaption>
          <span class="gallery-item__kind">{item.type === "reel" ? "Reel" : "Foto"}</span>
        </figcaption>
      </figure>
    ))}
  </div>
)}

<style>
  .case-gallery {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .gallery-item {
    position: relative;
    margin: 0;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 10px;
    overflow: hidden;
    background: rgba(11, 24, 48, 0.7);
    aspect-ratio: 9 / 16;
  }

  .gallery-item img,
  .gallery-item video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .gallery-item--reel {
    border-color: rgba(230, 95, 64, 0.4);
  }

  .gallery-item figcaption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 10px 12px;
    background: linear-gradient(0deg, rgba(5, 15, 35, 0.86), transparent);
    pointer-events: none;
  }

  .gallery-item__kind {
    color: var(--frato-orange);
    font-size: 0.66rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* Video controls need pointer events even though caption sits above. */
  .gallery-item--reel figcaption {
    bottom: auto;
    top: 0;
    background: linear-gradient(180deg, rgba(5, 15, 35, 0.86), transparent);
  }

  @media (max-width: 860px) {
    .case-gallery {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 480px) {
    .case-gallery {
      grid-template-columns: 1fr;
    }
  }
</style>

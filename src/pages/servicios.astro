---
import SocialContactActions from "~/components/SocialContactActions.astro";
import MarketingLayout from "~/layouts/MarketingLayout.astro";

export const prerender = true;

const serviceCards = [
  ["Estrategia de marca", "Diagnostico, direccion narrativa, tono, pilares de contenido y ruta de accion para ordenar la comunicacion."],
  ["Gestion de redes sociales", "Planeacion, programacion, acompanamiento editorial, historias, publicaciones y seguimiento mensual."],
  ["Produccion foto + video", "Sesiones de producto, reels, cubrimientos, piezas audiovisuales y material para alimentar la presencia digital."],
  ["Contenido movil", "Contenido dinamico para stories, reels y momentos cotidianos de la marca con mirada estrategica."],
  ["Diseno grafico", "Piezas visuales para campanas, lanzamientos, feed, historias y necesidades comerciales de la marca."],
  ["Pauta y campanas", "Creativos, segmentacion, seguimiento y lectura de resultados para campanas digitales."],
];

const services = [
  "Asesorias y reuniones creativas de marca",
  "Estrategia de contenido y narrativa",
  "Gestion de redes sociales",
  "Produccion profesional foto + video",
  "Contenido de celular para reels y stories",
  "Diseno grafico para piezas de marca",
];

const alliances = ["Patente de Noticias"];
---

<MarketingLayout title="Servicios - frato">
  <section class="services-hero">
    <div class="container grid-2">
      <div>
        <h1 class="headline">Servicios con estrategia antes de ejecucion.</h1>
        <p class="lead">Aqui reunimos lo que hacemos para marcas que necesitan pensar mejor, contar mejor y producir con direccion. Sin tarifas publicas: cada propuesta se arma segun el reto de la marca.</p>
        <SocialContactActions />
      </div>
      <div class="service-stack">
        {services.map((service, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{service}</strong>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-tight" id="lo-que-hacemos">
    <div class="container service-cards">
      {serviceCards.map(([name, body]) => (
        <article>
          <span>{name}</span>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-tight alliances" id="alianzas">
    <div class="container alliances__inner">
      <div>
        <p class="eyeless-label">Alianzas estrategicas</p>
        <h2 class="headline">Redes que amplifican la historia.</h2>
        <p class="lead">Colaboramos con aliados puntuales para darle mas alcance y contexto a las marcas cuando la estrategia lo necesita.</p>
      </div>
      <div class="alliance-logos" aria-label="Marcas aliadas">
        {alliances.map((name) => (
          <span>{name}</span>
        ))}
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .services-hero {
    min-height: calc(94vh - 76px);
    display: grid;
    align-items: center;
    padding: clamp(58px, 8vw, 110px) 0;
  }

  .services-hero h1,
  .services-hero p {
    margin: 0 0 24px;
  }

  .service-stack {
    display: grid;
    gap: 10px;
  }

  .service-stack article {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr);
    gap: 16px;
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: 8px;
    padding: 16px;
    background: rgba(11, 24, 48, 0.72);
  }

  .service-stack span,
  .service-cards span {
    color: var(--frato-orange);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.16em;
    line-height: 1.25;
    text-transform: uppercase;
  }

  .service-stack strong {
    color: rgba(255, 255, 255, 0.86);
    line-height: 1.25;
  }

  .service-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .service-cards article {
    display: grid;
    align-content: start;
    gap: 16px;
    min-height: 220px;
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: 8px;
    padding: 24px;
    background: rgba(11, 24, 48, 0.72);
  }

  .service-cards p,
  .alliances p {
    margin: 0;
    color: rgba(255, 255, 255, 0.68);
    line-height: 1.6;
  }

  .alliances {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent);
  }

  .alliances__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.55fr);
    gap: clamp(28px, 6vw, 70px);
    align-items: center;
  }

  .alliances h2,
  .alliances p {
    margin: 0 0 18px;
  }

  .alliance-logos {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: flex-start;
  }

  .alliance-logos span {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    padding: 0 18px;
    background: rgba(11, 24, 48, 0.48);
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  @media (max-width: 980px) {
    .service-cards {
      grid-template-columns: repeat(2, 1fr);
    }

    .alliances__inner {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .service-cards {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import BrandLogo from "~/components/BrandLogo.astro";
import BrandMarquee from "~/components/BrandMarquee.astro";
import SocialContactActions from "~/components/SocialContactActions.astro";
import MarketingLayout from "~/layouts/MarketingLayout.astro";

export const prerender = true;

---

<MarketingLayout>
  <section class="home-video" aria-label="Video de inicio de frato">
    <div class="home-video__frame">
      <video
        class="home-video__media"
        src="/assets/video/frato-inicio.mp4"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
      ></video>
      <a class="home-video__cue" href="#inicio-frato" aria-label="Ir al contenido principal">
        <span></span>
      </a>
    </div>
  </section>

  <section class="hero-lab" id="inicio-frato">
    <div class="container hero-lab__stack">
      <div class="hero-lab__copy reveal-in">
        <h1 class="display">Narrativa estrategica para marcas con vision.</h1>
        <p class="lead">Somos una agencia especializada de marketing con mas de tres anos de experiencia en el mercado y mas de treinta marcas trabajadas.</p>
      </div>

      <div class="btn-row hero-lab__actions">
        <a class="btn btn-primary" href="/contacto">Agendar reunion creativa</a>
        <a class="btn btn-secondary" href="/servicios">Ver servicios</a>
      </div>

    </div>

    <div class="container hero-lab__proof">
      <span>+3 anos de experiencia</span>
      <span>+30 marcas trabajadas</span>
      <span>Estrategia, contenido y produccion</span>
    </div>
  </section>

  <section class="section-tight manifesto">
    <div class="container manifesto__inner">
      <h2 class="headline">Agencia focal en narrativa estrategica para marcas con vision.</h2>
    </div>
  </section>

  <section class="section-tight agency-note">
    <div class="container agency-note__inner">
      <p class="eyeless-label">Lo principal</p>
      <h2 class="headline">Marketing que entiende la marca antes de producir contenido.</h2>
      <p class="lead">En frato convertimos ideas, productos y experiencias en historias con direccion. Acompanamos marcas que necesitan claridad, criterio y una presencia digital con sentido.</p>
    </div>
  </section>

  <div id="marcas-aliadas">
    <BrandMarquee />
  </div>

  <section class="section final-cta">
    <div class="container final-cta__panel">
      <BrandLogo />
      <h2 class="headline">Empezamos entendiendo. Despues, producimos.</h2>
      <SocialContactActions />
    </div>
  </section>
</MarketingLayout>

<style>
  .home-video {
    position: relative;
    min-height: calc(100vh - 76px);
    display: grid;
    align-items: stretch;
    padding: 0;
    overflow: hidden;
    background: var(--frato-bg);
  }

  .home-video::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 34vh;
    pointer-events: none;
    z-index: 3;
    background: linear-gradient(180deg, transparent, rgba(25, 25, 25, 0.72) 58%, var(--frato-bg));
  }

  .home-video__frame {
    position: relative;
    overflow: hidden;
    width: 100%;
    min-height: calc(100vh - 76px);
    background: var(--frato-bg);
  }

  .home-video__frame::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(circle at 50% 48%, transparent 36%, rgba(25, 25, 25, 0.18) 68%, rgba(25, 25, 25, 0.62) 100%),
      linear-gradient(180deg, rgba(25, 25, 25, 0.28), transparent 22%, transparent 58%, rgba(25, 25, 25, 0.48));
  }

  .home-video__frame::after {
    content: "";
    position: absolute;
    inset: clamp(14px, 2.2vw, 28px);
    z-index: 2;
    pointer-events: none;
    border: 1px solid rgba(255, 255, 255, 0.09);
  }

  .home-video__media {
    width: 100%;
    height: calc(100vh - 76px);
    min-height: 560px;
    display: block;
    object-fit: cover;
    background: var(--frato-black);
  }

  .home-video__cue {
    position: absolute;
    left: 50%;
    bottom: clamp(24px, 5vw, 58px);
    z-index: 4;
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    background: rgba(25, 25, 25, 0.36);
    transform: translateX(-50%);
    transition: border-color 180ms ease, transform 180ms ease, background 180ms ease;
  }

  .home-video__cue:hover {
    border-color: rgba(230, 95, 64, 0.8);
    background: rgba(230, 95, 64, 0.14);
    transform: translateX(-50%) translateY(-2px);
  }

  .home-video__cue span {
    width: 10px;
    height: 10px;
    border-right: 2px solid rgba(255, 255, 255, 0.8);
    border-bottom: 2px solid rgba(255, 255, 255, 0.8);
    transform: translateY(-2px) rotate(45deg);
  }

  .hero-lab {
    min-height: calc(100vh - 76px);
    display: grid;
    align-content: center;
    gap: 28px;
    padding: clamp(48px, 6vw, 80px) 0 28px;
    overflow: hidden;
  }

  .hero-lab__stack {
    display: grid;
    gap: clamp(24px, 3.5vw, 40px);
    align-content: end;
  }

  .hero-lab__copy {
    display: grid;
    gap: 18px;
    max-width: 920px;
  }

  .hero-lab__copy h1,
  .hero-lab__copy p {
    margin: 0;
  }

  .hero-lab__actions {
    justify-content: center;
  }

  .agency-note {
    background: var(--frato-bg);
  }

  .agency-note__inner {
    display: grid;
    gap: 18px;
    max-width: 900px;
  }

  .agency-note__inner h2,
  .agency-note__inner p {
    margin: 0;
  }

  .hero-lab__proof {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    border-top: 1px solid var(--frato-line);
    padding-top: 18px;
  }

  .hero-lab__proof span {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.92rem;
  }

  .manifesto {
    background: var(--frato-orange);
    color: #120804;
  }

  .manifesto__inner {
    display: flex;
    justify-content: center;
  }

  .manifesto .headline {
    max-width: 1040px;
    margin: 0;
    color: inherit;
    text-align: center;
  }

  .final-cta {
    text-align: center;
  }

  .final-cta__panel {
    display: grid;
    justify-items: center;
    gap: 24px;
    border-top: 1px solid var(--frato-line);
    padding-top: clamp(38px, 6vw, 70px);
  }

  .final-cta__panel > img {
    width: min(190px, 52vw);
  }

  @media (max-width: 900px) {
    .home-video {
      min-height: auto;
      padding: 0;
    }

    .home-video__media {
      height: min(72vh, 620px);
      min-height: 420px;
    }

    .hero-lab {
      min-height: auto;
      align-content: start;
    }

    .hero-lab__grid,
    .hero-lab__proof {
      grid-template-columns: 1fr;
    }
  }
</style>
